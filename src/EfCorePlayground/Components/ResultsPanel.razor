@using EfCorePlayground.Services

<div class="card flex-grow-1 d-flex flex-column overflow-auto h-100">
    <div class="card-header py-2 d-flex justify-content-between align-items-center
                @(Result != null && !Result.Success ? "bg-danger text-white" : "bg-info text-white")">
        <span>
            <i class="bi me-1 @(Result != null && !Result.Success ? "bi-x-circle" : "bi-table")"></i>
            Résultats
        </span>
        @if (Result != null)
        {
            <span class="badge @(Result.Success ? "bg-light text-dark" : "bg-light text-danger")">
                @Result.Output
            </span>
        }
    </div>
    <div class="card-body p-0 flex-grow-1 overflow-auto" id="results-panel">
        @if (IsExecuting)
        {
            <div class="d-flex justify-content-center align-items-center h-100">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
            </div>
        }
        else if (Result == null)
        {
            <div class="d-flex flex-column justify-content-center align-items-center h-100 text-muted">
                <i class="bi bi-play-circle" style="font-size: 3rem;"></i>
                <p class="mt-2">Cliquez sur <strong>Exécuter</strong> pour voir les résultats</p>
            </div>
        }
        else if (!Result.Success)
        {
            <div class="p-3">
                @if (Result.Errors?.Count > 0)
                {
                    @foreach (var error in Result.Errors)
                    {
                        <div class="alert alert-danger py-2 mb-1 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            <strong>@error.Id</strong>
                            @if (error.Line > 0)
                            {
                                <span> (ligne @error.Line)</span>
                            }
                            : @error.Message
                        </div>
                    }
                }
                else
                {
                    <pre class="text-danger small">@Result.Output</pre>
                }
            </div>
        }
        else if (Result.Columns?.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm mb-0" id="results-table">
                    <thead class="table-dark sticky-top">
                        <tr>
                            @foreach (var col in Result.Columns)
                            {
                                <th class="small">@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Result.Rows != null)
                        {
                            @foreach (var row in Result.Rows)
                            {
                                <tr>
                                    @foreach (var col in Result.Columns)
                                    {
                                        <td class="small">
                                            @if (row.TryGetValue(col, out var value) && value != null)
                                            {
                                                @FormatValue(value)
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">null</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-3">
                <pre class="bg-light p-3 rounded small">@Result.Output</pre>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public ExecutionResult? Result { get; set; }
    [Parameter] public bool IsExecuting { get; set; }

    private string FormatValue(object? value)
    {
        if (value == null) return "null";
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.String => je.GetString() ?? "",
                System.Text.Json.JsonValueKind.Number => je.GetRawText(),
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                System.Text.Json.JsonValueKind.Null => "null",
                _ => je.GetRawText()
            };
        }
        return value.ToString() ?? "";
    }
}
