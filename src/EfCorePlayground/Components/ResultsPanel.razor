@using EfCorePlayground.Services
@inject IJSRuntime JS

<div class="card flex-grow-1 d-flex flex-column overflow-auto h-100">
    <div class="card-header py-2 d-flex justify-content-between align-items-center
                @(Result != null && !Result.Success ? "bg-danger text-white" : "bg-info text-white")">
        <span>
            <i class="bi me-1 @(Result != null && !Result.Success ? "bi-x-circle" : "bi-table")"></i>
            Résultats
        </span>
        @if (Result != null)
        {
            <span class="badge @(Result.Success ? "bg-light text-dark" : "bg-light text-danger")">
                @Result.Output
            </span>
        }
    </div>
    <div class="card-body p-0 flex-grow-1 overflow-auto d-flex flex-column" id="results-panel">
        @if (IsExecuting)
        {
            <div class="d-flex justify-content-center align-items-center h-100">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
            </div>
        }
        else if (Result == null)
        {
            <div class="d-flex flex-column justify-content-center align-items-center h-100 text-muted">
                <i class="bi bi-play-circle" style="font-size: 3rem;"></i>
                <p class="mt-2">Cliquez sur <strong>Exécuter</strong> pour voir les résultats</p>
            </div>
        }
        else if (!Result.Success)
        {
            <div class="p-3">
                @if (Result.Errors?.Count > 0)
                {
                    @foreach (var error in Result.Errors)
                    {
                        <div class="alert alert-danger py-2 mb-1 small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            <strong>@error.Id</strong>
                            @if (error.Line > 0)
                            {
                                <span> (ligne @error.Line)</span>
                            }
                            : @error.Message
                        </div>
                    }
                }
                else
                {
                    <pre class="text-danger small">@Result.Output</pre>
                }
            </div>
        }
        else
        {
            @* Data results *@
            @if (Result.Columns?.Count > 0)
            {
                <div class="table-responsive flex-shrink-0" style="max-height: 50%;">
                    <table class="table table-striped table-hover table-sm mb-0" id="results-table">
                        <thead class="table-dark sticky-top">
                            <tr>
                                @foreach (var col in Result.Columns)
                                {
                                    <th class="small">@col</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (Result.Rows != null)
                            {
                                @foreach (var row in Result.Rows)
                                {
                                    <tr>
                                        @foreach (var col in Result.Columns)
                                        {
                                            <td class="small">
                                                @if (row.TryGetValue(col, out var value) && value != null)
                                                {
                                                    @FormatValue(value)
                                                }
                                                else
                                                {
                                                    <span class="text-muted fst-italic">null</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 flex-shrink-0">
                    <pre class="bg-light p-3 rounded small">@Result.Output</pre>
                </div>
            }

            @* Generated SQL panel *@
            @if (!string.IsNullOrEmpty(Result.GeneratedSql))
            {
                <div class="border-top flex-grow-1 d-flex flex-column" style="min-height: 120px;">
                    <div class="bg-dark text-white py-1 px-2 small d-flex justify-content-between align-items-center flex-shrink-0">
                        <span>
                            <i class="bi bi-database me-1"></i> SQL généré
                            <span class="text-secondary ms-1">(@Result.CapturedQueries!.Count requête(s))</span>
                        </span>
                        <button class="btn btn-sm btn-outline-light py-0 px-1" @onclick="CopySql" title="Copier le SQL">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>

                    @* Per-query summary badges (shown when TagWith or metadata is present) *@
                    @if (Result.CapturedQueries!.Any(q => q.Tag != null || q.RowCount.HasValue))
                    {
                        var ranges = GetQueryLineRanges(Result.CapturedQueries!);
                        <div class="px-2 py-1 bg-black border-bottom border-secondary d-flex flex-wrap gap-1 flex-shrink-0">
                            @foreach (var (q, i) in Result.CapturedQueries!.Select((q, i) => (q, i)))
                            {
                                var isGood = q.Tag?.StartsWith("✅") == true;
                                var isBad  = q.Tag?.StartsWith("❌") == true;
                                var pillCss = isBad ? "bg-danger" : isGood ? "bg-success" : "bg-secondary";
                                var label = q.Tag ?? $"Requête {i + 1}";
                                var startLine = ranges[i].Start;
                                var endLine   = ranges[i].End;
                                <span class="badge @pillCss d-inline-flex align-items-center gap-1 text-wrap text-start"
                                      style="cursor: default; max-width:100%"
                                      title="Survolez pour mettre en évidence dans le SQL"
                                      @onmouseenter="@(() => HighlightSqlRange(startLine, endLine))"
                                      @onmouseleave="ClearSqlHighlight">
                                    @label
                                    @if (q.ColumnCount.HasValue && q.ColumnCount > 0)
                                    {
                                        <span class="badge bg-light text-dark">@q.ColumnCount col.</span>
                                    }
                                    @if (q.RowCount.HasValue)
                                    {
                                        var rowLabel = q.ColumnCount.HasValue && q.ColumnCount > 0
                                            ? $"{q.RowCount} ligne(s)"
                                            : $"{q.RowCount} affectée(s)";
                                        <span class="badge bg-light text-dark">@rowLabel</span>
                                    }
                                    @if (q.TrackedEntities.HasValue)
                                    {
                                        var trackCss = q.TrackedEntities > 0 ? "bg-warning text-dark" : "bg-light text-dark";
                                        <span class="badge @trackCss" title="Entités dans le ChangeTracker après cette requête">
                                            @q.TrackedEntities tracked
                                        </span>
                                    }
                                </span>
                            }
                        </div>
                    }

                    <div id="sql-viewer-container" class="flex-grow-1" style="min-height: 80px;"></div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public ExecutionResult? Result { get; set; }
    [Parameter] public bool IsExecuting { get; set; }

    private string? _lastSql;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentSql = Result?.GeneratedSql;
        if (currentSql != _lastSql)
        {
            _lastSql = currentSql;
            if (!string.IsNullOrEmpty(currentSql))
            {
                // Small delay to ensure the container element exists in DOM
                await Task.Delay(50);
                await JS.InvokeVoidAsync("monacoInterop.createSqlViewer", "sql-viewer-container", currentSql);
            }
        }
    }

    private async Task CopySql()
    {
        if (!string.IsNullOrEmpty(Result?.GeneratedSql))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Result.GeneratedSql);
        }
    }

    /// <summary>
    /// Computes the 1-based start/end line of each query in the joined SQL string.
    /// Queries are separated by \n\n (one blank line) in GeneratedSql.
    /// </summary>
    private static (int Start, int End)[] GetQueryLineRanges(List<CapturedQuery> queries)
    {
        var ranges = new (int Start, int End)[queries.Count];
        int currentLine = 1;
        for (int i = 0; i < queries.Count; i++)
        {
            int lineCount = queries[i].Sql.Count(c => c == '\n') + 1;
            ranges[i] = (currentLine, currentLine + lineCount - 1);
            currentLine += lineCount + 1; // +1 for the blank separator line (\n\n)
        }
        return ranges;
    }

    private async Task HighlightSqlRange(int startLine, int endLine)
        => await JS.InvokeVoidAsync("monacoInterop.highlightSqlRange", startLine, endLine);

    private async Task ClearSqlHighlight()
        => await JS.InvokeVoidAsync("monacoInterop.clearSqlHighlight");

    private string FormatValue(object? value)
    {
        if (value == null) return "null";
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.String => je.GetString() ?? "",
                System.Text.Json.JsonValueKind.Number => je.GetRawText(),
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                System.Text.Json.JsonValueKind.Null => "null",
                _ => je.GetRawText()
            };
        }
        return value.ToString() ?? "";
    }
}
